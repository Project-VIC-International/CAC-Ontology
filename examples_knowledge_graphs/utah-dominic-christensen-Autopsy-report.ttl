    uco-core:name "Utah ICAC DF Examiner (example persona)"@en ;
    uco-core:hasRole kb:role-taskforce-forensic-examiner-8c5e3c76-1bf8-4b3d-a842-6e4cc5b1f060 ;
    uco-core:description "Examiner identity used to anchor actions/provenance in this demo output."@en .

kb:role-taskforce-forensic-examiner-8c5e3c76-1bf8-4b3d-a842-6e4cc5b1f060 a cacontology-taskforce:TaskForceForensicExaminer ,
        cacontology-forensics:ForensicExaminerRole ;
    rdfs:label "Utah ICAC Task Force forensic examiner role (demo)"@en ;
    cacontology-forensics:hasRoleBeginPoint "2025-01-01T00:00:00Z"^^xsd:dateTimeStamp ;
    cacontology-forensics:certificationLevel "certified" ;
    uco-core:description "Role instance representing a Utah ICAC digital forensic examiner."@en .

