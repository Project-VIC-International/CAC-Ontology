# Record the query used (demo) to support auditability and re-execution
kb:observable-sparql-query-8a7b6c5d-4e3f-4a2b-9c1d-0e1f2a3b4c5d a uco-observable:ObservableObject ;
    rdfs:label "SPARQL query used for cross-graph enrichment (demo)"@en ;
    uco-core:hasFacet kb:facet-query-content-0b1c2d3e-4f5a-4b6c-8d7e-9f0a1b2c3d4e ,
                     kb:facet-query-hash-1b2c3d4e-5f60-4a7b-8c9d-0e1f2a3b4c5d ;
    dcterms:description """SPARQL (demo):

PREFIX cacontology-registry: <https://cacontology.projectvic.org/sex-offender-registry#>
PREFIX uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/>

SELECT ?person ?acct WHERE {
  ?acct a uco-observable:DigitalAccount ;
        uco-observable:accountIdentifier "dominic.christensen@examplemail.com" .
  ?person ?p ?o .
}

NOTE: In production, the query would target the intelligence repository named graph and join by account + identity; this is simplified for demo readability."""@en .

