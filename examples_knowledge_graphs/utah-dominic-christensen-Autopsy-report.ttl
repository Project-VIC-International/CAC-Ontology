    rdfs:label "Examiner member-of Utah ICAC Task Force"@en ;
    uco-core:source kb:person-examiner-7b3b4a87-3c7a-4f4d-9f4e-2d1c17c8288a ;
    uco-core:target kb:org-utah-icac-task-force ;
    uco-core:kindOfRelationship "member-of" ;
    uco-core:isDirectional true ;
    uco-core:description "Links examiner to the Utah ICAC Task Force organization."@en .

