@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix uco-identity: <https://ontology.unifiedcyberontology.org/uco/identity/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@prefix uco-action: <https://ontology.unifiedcyberontology.org/uco/action/> .
@prefix uco-role: <https://ontology.unifiedcyberontology.org/uco/role/> .
@prefix cacontology-hotlines: <https://cacontology.projectvic.org/hotlines#> .

# Example Report
cacontology-hotlines:report-2024-001 a cacontology-hotlines:PublicReport ;
    rdfs:label "Report #2024-001"@en ;
    cacontology-hotlines:reportedBy cacontology-hotlines:reporter-001 ;
    cacontology-hotlines:receivedBy cacontology-hotlines:org-001 ;
    cacontology-hotlines:hasEvidence cacontology-hotlines:evidence-001 ;
    cacontology-hotlines:intakeChannel cacontology-hotlines:web-form ;
    cacontology-hotlines:status cacontology-hotlines:status-closed ;
    cacontology-hotlines:triggersAction cacontology-hotlines:action-review-001 ;
    cacontology-hotlines:triggersAction cacontology-hotlines:action-hash-001 ;
    cacontology-hotlines:triggersAction cacontology-hotlines:action-forward-001 .

# Reporter (Anonymous)
cacontology-hotlines:reporter-001 a cacontology-hotlines:ReporterRole ;
    rdfs:label "Anonymous Reporter"@en ;
    cacontology-hotlines:isAnonymous true ;
    cacontology-hotlines:roleAssignmentTime "2024-03-20T09:00:00Z"^^xsd:dateTime .

# Organization
cacontology-hotlines:org-001 a cacontology-hotlines:HotlineOrganization ;
    rdfs:label "Example Hotline"@en ;
    uco-core:name "National Child Safety Hotline" .

# Evidence (URL)
cacontology-hotlines:evidence-001 a cacontology-hotlines:URLReference ;
    rdfs:label "Suspicious URL"@en ;
    uco-core:hasFacet cacontology-hotlines:url-facet-001 ;
    cacontology-hotlines:firstSeen "2024-03-20T10:00:00Z"^^xsd:dateTime .

cacontology-hotlines:url-facet-001 a uco-observable:URLFacet ;
    uco-observable:urlValue "https://example.com/suspicious"^^xsd:anyURI .

# Intake Channel
cacontology-hotlines:web-form a cacontology-hotlines:IntakeChannel ;
    rdfs:label "Web Form"@en .

# Status
cacontology-hotlines:status-closed a cacontology-hotlines:HotlineCaseStatus ;
    rdfs:label "Closed"@en .

# Actions
cacontology-hotlines:action-review-001 a cacontology-hotlines:ReportReviewAction ;
    rdfs:label "Initial Review"@en ;
    uco-core:startTime "2024-03-20T10:05:00Z"^^xsd:dateTime ;
    uco-core:endTime "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    uco-action:performer cacontology-hotlines:analyst-001 ;
    cacontology-hotlines:classification cacontology-hotlines:class-csam ;
    cacontology-hotlines:nextStep cacontology-hotlines:action-hash-001 .

cacontology-hotlines:action-hash-001 a cacontology-hotlines:HashSubmissionAction ;
    rdfs:label "Hash Submission"@en ;
    uco-core:startTime "2024-03-20T10:16:00Z"^^xsd:dateTime ;
    uco-core:endTime "2024-03-20T10:20:00Z"^^xsd:dateTime ;
    uco-action:performer cacontology-hotlines:analyst-001 ;
    cacontology-hotlines:producesHash cacontology-hotlines:hash-001 ;
    cacontology-hotlines:previousStep cacontology-hotlines:action-review-001 ;
    cacontology-hotlines:nextStep cacontology-hotlines:action-forward-001 .

cacontology-hotlines:action-forward-001 a cacontology-hotlines:ForwardToLEAction ;
    rdfs:label "Forward to LE"@en ;
    uco-core:startTime "2024-03-20T10:21:00Z"^^xsd:dateTime ;
    uco-core:endTime "2024-03-20T10:25:00Z"^^xsd:dateTime ;
    uco-action:performer cacontology-hotlines:analyst-001 ;
    cacontology-hotlines:forwardsTo cacontology-hotlines:le-org-001 ;
    cacontology-hotlines:previousStep cacontology-hotlines:action-hash-001 .

# Supporting Instances
cacontology-hotlines:analyst-001 a uco-identity:Identity ;
    rdfs:label "Analyst John Doe"@en ;
    uco-identity:hasRole cacontology-hotlines:role-analyst .

cacontology-hotlines:role-analyst a uco-role:Role ;
    rdfs:label "Hotline Analyst"@en .

cacontology-hotlines:class-csam a cacontology-hotlines:ClassificationLabel ;
    rdfs:label "CSAM"@en .

cacontology-hotlines:hash-001 a uco-observable:Hash ;
    rdfs:label "MD5 Hash"@en ;
    uco-observable:hashMethod "MD5"^^xsd:string ;
    uco-observable:hashValue "d41d8cd98f00b204e9800998ecf8427e"^^xsd:hexBinary .

cacontology-hotlines:le-org-001 a uco-identity:Organization ;
    rdfs:label "Example Law Enforcement"@en .

# Example of Hash Feedback
cacontology-hotlines:action-feedback-001 a cacontology-hotlines:HashFeedbackAction ;
    rdfs:label "Hash Feedback"@en ;
    uco-core:startTime "2024-03-21T09:00:00Z"^^xsd:dateTime ;
    uco-core:endTime "2024-03-21T09:05:00Z"^^xsd:dateTime ;
    uco-action:performer cacontology-hotlines:analyst-001 ;
    cacontology-hotlines:referencesHash cacontology-hotlines:hash-001 ;
    cacontology-hotlines:feedbackType "Removed" . 