    rdfs:label "Search Warrant to Email Service Provider"@en ;
    rdfs:comment "Search warrant issued to the email provider for information on the registered owner of the account implicated in the cybertip."@en .

ex:370bb6ab-2b2f-5bc1-b483-2a2fbd8459f3 rdf:type uco-action:Action ;
